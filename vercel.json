{
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(self), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/robots.txt",            "destination": "/api/index.py" },
    { "source": "/sitemap.xml",           "destination": "/api/index.py" },
    { "source": "/api/(.*)",              "destination": "/api/index.py" },
    { "source": "/app",                   "destination": "/app/index.html" },
    { "source": "/app/",                  "destination": "/app/index.html" },
    { "source": "/dashboard",             "destination": "/dashboard/index.html" },
    { "source": "/dashboard/",            "destination": "/dashboard/index.html" },
    { "source": "/dashboard/login",       "destination": "/dashboard/login.html" },
    { "source": "/dashboard/register",   "destination": "/dashboard/register.html" },
    { "source": "/dashboard/case",       "destination": "/dashboard/case.html" },
    { "source": "/admin",                "destination": "/admin/index.html" },
    { "source": "/admin/",               "destination": "/admin/index.html" },
    { "source": "/admin/login",          "destination": "/admin/login.html" },
    { "source": "/avis",                 "destination": "/avis/index.html" },
    { "source": "/mentions-legales",     "destination": "/mentions-legales/index.html" },
    { "source": "/confidentialite",      "destination": "/confidentialite/index.html" },
    { "source": "/cgu",                  "destination": "/cgu/index.html" },
    { "source": "/blog",                            "destination": "/blog/index.html" },
    { "source": "/blog/",                           "destination": "/blog/index.html" },
    { "source": "/blog/expulsion-locative",         "destination": "/blog/expulsion-locative.html" },
    { "source": "/blog/mise-en-demeure",            "destination": "/blog/mise-en-demeure.html" },
    { "source": "/blog/oqtf-droits",                "destination": "/blog/oqtf-droits.html" },
    { "source": "/blog/licenciement-abusif",        "destination": "/blog/licenciement-abusif.html" },
    { "source": "/blog/clause-abusive-bail",        "destination": "/blog/clause-abusive-bail.html" },
    { "source": "/blog/contester-oqtf-2026",        "destination": "/blog/contester-oqtf-2026.html" },
    { "source": "/blog/avis-expulsion-locataire-droits", "destination": "/blog/avis-expulsion-locataire-droits.html" },
    { "source": "/blog/refus-titre-sejour-recours", "destination": "/blog/refus-titre-sejour-recours.html" }
  ]
}
